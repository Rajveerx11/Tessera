#!/usr/bin/env sh
# Pre-commit guard — fast checks only, must finish in seconds.
#
# Heavier checks (typecheck, lint, tests) run in pre-push. Keeping
# pre-commit tight prevents devs from disabling it.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# 1. Refuse commits with unresolved Git conflict markers.
bash "$REPO_ROOT/tools/scripts/pre-push-no-markers.sh"

# 2. Block accidental commits of huge files (> 5 MB) that should not
#    live in git history.
LARGE_FILES="$(git diff --cached --name-only --diff-filter=AM | while read -r f; do
  if [ -f "$f" ]; then
    size_bytes=$(wc -c < "$f" 2>/dev/null || echo 0)
    if [ "$size_bytes" -gt 5242880 ]; then
      echo "$f ($((size_bytes / 1024 / 1024)) MB)"
    fi
  fi
done)"

if [ -n "$LARGE_FILES" ]; then
  echo "ERROR: refusing to commit files larger than 5 MB:" >&2
  echo "$LARGE_FILES" >&2
  echo "" >&2
  echo "Move large assets out of the repo (e.g. release attachments)." >&2
  echo "Bypass with --no-verify only if absolutely required." >&2
  exit 1
fi

exit 0
